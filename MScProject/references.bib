}

@article{espositoCorrelationArchitecturalSmells2025,
  title = {On the Correlation between Architectural Smells and Static Analysis Warnings},
  author = {Esposito, Matteo and Robredo, Mikel and Arcelli Fontana, Francesca and Lenarduzzi, Valentina},
  year = 2025,
  month = oct,
  journal = {Software Quality Journal},
