  title = {Technical {{Debt}} in {{Service-Oriented Software Systems}}},
  booktitle = {Product-{{Focused Software Process Improvement}}},
  author = {Nikolaidis, Nikolaos and Ampatzoglou, Apostolos and Chatzigeorgiou, Alexander and Tsekeridou, Sofia and Piperidis, Avraam},
